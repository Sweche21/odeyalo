<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/wellbeing-ontology"
         xmlns="http://example.org/wellbeing-ontology#">

<owl:Ontology rdf:about="http://example.org/wellbeing-ontology"/>

<owl:ObjectProperty rdf:about="#Includes">
  <rdfs:domain rdf:resource="#Indicator"/>
  <rdfs:range rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Включает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Influences">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Влияет</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Vhodyat">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">входят</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Causes">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Вызывает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Identifies">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#InternalFactor"/>
        <rdf:Description rdf:about="#Indicator"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Выявляет</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Supplements">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range rdf:resource="#Exercise"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Дополняет</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Moderates">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Модерирует</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Motivates">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Мотивирует</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Assesses">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Test"/>
        <rdf:Description rdf:about="#Exercise"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#InternalFactor"/>
        <rdf:Description rdf:about="#Indicator"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Оценивает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Helps">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Помогает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Explains">
  <rdfs:domain rdf:resource="#Theory"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Exercise"/>
        <rdf:Description rdf:about="#InternalFactor"/>
        <rdf:Description rdf:about="#Indicator"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Поясняет</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Overcomes">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Преодалевает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#WorksThrough">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Прорабатывает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ProyavlyayutsyaV">
  <rdfs:domain rdf:resource="#InternalFactor"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">проявляются в</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Reduces">
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="#Theory"/>
        <rdf:Description rdf:about="#Indicator"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Снижает</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#Records">
  <rdfs:domain rdf:resource="#Exercise"/>
  <rdfs:range rdf:resource="#InternalFactor"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Фиксирует</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasObservation">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="#Observation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#observedBy">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="#User"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#aboutIndicator">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="#IndicatorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#aboutFactor">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="#FactorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasRecommendation">
  <rdfs:domain rdf:resource="#User"/>
  <rdfs:range rdf:resource="#Recommendation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#recommendsTask">
  <rdfs:domain rdf:resource="#Recommendation"/>
  <rdfs:range rdf:resource="#TherapeuticTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#recommendationFor">
  <rdfs:domain rdf:resource="#Recommendation"/>
  <rdfs:range rdf:resource="#User"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#triggeredBy">
  <rdfs:domain rdf:resource="#Recommendation"/>
  <rdfs:range rdf:resource="#Observation"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targetsIndicator">
  <rdfs:domain rdf:resource="#TherapeuticTask"/>
  <rdfs:range rdf:resource="#IndicatorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#targetsFactor">
  <rdfs:domain rdf:resource="#TherapeuticTask"/>
  <rdfs:range rdf:resource="#FactorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ruleForIndicator">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="#IndicatorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ruleForFactor">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="#FactorConcept"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ruleMinSeverity">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="#SeverityLevel"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#ruleRecommendsTask">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="#TherapeuticTask"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#matchesRule">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="#Rule"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#observationValue">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#observationTime">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#observationSource">
  <rdfs:domain rdf:resource="#Observation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#recommendationText">
  <rdfs:domain rdf:resource="#Recommendation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#recommendationScore">
  <rdfs:domain rdf:resource="#Recommendation"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#ruleWeight">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#ruleWhy">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#ruleSWRL">
  <rdfs:domain rdf:resource="#Rule"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
</owl:DatatypeProperty>

<owl:AnnotationProperty rdf:about="#ruLabel"/>

<owl:AnnotationProperty rdf:about="#originClassIri"/>

<owl:Class rdf:about="#Indicator">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#InternalFactor">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Exercise">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Test">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Theory">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#User">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Observation">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#IndicatorConcept">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#FactorConcept">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Recommendation">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#TherapeuticTask">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Rule">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#SeverityLevel">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Trevozhnost">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#Includes"/>
      <owl:someValuesFrom rdf:resource="#Trevoga"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Тревожность</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Тревожность</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Trevoga">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#Chuvstva"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Тревога</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Тревога</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Chuvstva">
  <rdfs:subClassOf rdf:resource="#InternalFactor"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#Influences"/>
      <owl:someValuesFrom rdf:resource="#Nastroenie"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Чувства</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Чувства</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Nastroenie">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Настроение</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Настроение</ruLabel>
</owl:Class>

<owl:Class rdf:about="#DepressivnayaSimptomatika">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#Reduces"/>
      <owl:someValuesFrom rdf:resource="#Nastroenie"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Депрессивная симптоматика</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Депрессивная симптоматика</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Vygoranie">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Выгорание</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Выгорание</ruLabel>
</owl:Class>

<owl:Class rdf:about="#VosprinimaemyyStress">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Воспринимаемый стресс</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Воспринимаемый стресс</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Distress">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#VosprinimaemyyStress"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Дистресс</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Дистресс</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Sovladanie">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#VosprinimaemyyStress"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Совладание</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Совладание</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Situativnaya">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#Trevozhnost"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ситуативная</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ситуативная</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Lichnostnaya">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#Trevozhnost"/>

<owl:Class rdf:about="#Depressiya">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#DepressivnayaSimptomatika"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Депрессия</rdfs:label>

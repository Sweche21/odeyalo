</owl:Class>

<owl:Class rdf:about="#SomaticheskieProyavleniya">
  <rdfs:subClassOf rdf:resource="#Indicator"/>
  <rdfs:subClassOf rdf:resource="#DepressivnayaSimptomatika"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Соматические проявления</rdfs:label>
  <ruLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Соматические проявления</ruLabel>
</owl:Class>

<owl:Class rdf:about="#Istoschenie">
  <rdfs:subClassOf rdf:resource="#Indicator"/>

</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_anxiety_high_stai">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_Trevozhnost"/>
  <ruleMinSeverity rdf:resource="#SeverityHigh"/>
  <ruleRecommendsTask rdf:resource="#task_test_Stai"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_anxiety_high_stai</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.9</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">При высокой тревожности полезно уточнить состояние тестом STAI.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_Trevozhnost) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_anxiety_high_stai)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_depression_high_beck">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_DepressivnayaSimptomatika"/>
  <ruleMinSeverity rdf:resource="#SeverityHigh"/>
  <ruleRecommendsTask rdf:resource="#task_test_ShkalaDepressiiBeka"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_depression_high_beck</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">При высокой депрессивной симптоматике полезно пройти шкалу депрессии Бека.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_DepressivnayaSimptomatika) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_depression_high_beck)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_depression_medium_cbt_diary">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_DepressivnayaSimptomatika"/>
  <ruleMinSeverity rdf:resource="#SeverityMedium"/>
  <ruleRecommendsTask rdf:resource="#task_exercise_KptDnevnik"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_depression_medium_cbt_diary</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.9</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">КПТ-дневник помогает отслеживать и перерабатывать депрессивные проявления.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_DepressivnayaSimptomatika) ^ hasSeverity(?obs, :SeverityMedium) -&gt; matchesRule(?obs, :rule_depression_medium_cbt_diary)
Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_DepressivnayaSimptomatika) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_depression_medium_cbt_diary)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_depression_medium_mood_tracker">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_DepressivnayaSimptomatika"/>
  <ruleMinSeverity rdf:resource="#SeverityMedium"/>
  <ruleRecommendsTask rdf:resource="#task_exercise_TrekerNastroeniya"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_depression_medium_mood_tracker</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.8</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Трекер настроения помогает фиксировать динамику состояния.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_DepressivnayaSimptomatika) ^ hasSeverity(?obs, :SeverityMedium) -&gt; matchesRule(?obs, :rule_depression_medium_mood_tracker)
Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_DepressivnayaSimptomatika) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_depression_medium_mood_tracker)</ruleSWRL>
</owl:NamedIndividual>


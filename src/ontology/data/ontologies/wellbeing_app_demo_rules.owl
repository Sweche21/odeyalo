<owl:NamedIndividual rdf:about="#rule_perceived_stress_medium_breathing">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_VosprinimaemyyStress"/>
  <ruleMinSeverity rdf:resource="#SeverityMedium"/>
  <ruleRecommendsTask rdf:resource="#task_theory_DyhatelnyeTehniki"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_perceived_stress_medium_breathing</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">При повышенном воспринимаемом стрессе полезны дыхательные техники.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_VosprinimaemyyStress) ^ hasSeverity(?obs, :SeverityMedium) -&gt; matchesRule(?obs, :rule_perceived_stress_medium_breathing)
Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_VosprinimaemyyStress) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_perceived_stress_medium_breathing)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_perceived_stress_medium_relax">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_VosprinimaemyyStress"/>
  <ruleMinSeverity rdf:resource="#SeverityMedium"/>
  <ruleRecommendsTask rdf:resource="#task_theory_Relaksatsiya"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_perceived_stress_medium_relax</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.0</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Релаксация помогает снижать воспринимаемый стресс.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_VosprinimaemyyStress) ^ hasSeverity(?obs, :SeverityMedium) -&gt; matchesRule(?obs, :rule_perceived_stress_medium_relax)
Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_VosprinimaemyyStress) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_perceived_stress_medium_relax)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_perceived_stress_high_pss">
  <rdf:type rdf:resource="#Rule"/>
  <ruleForIndicator rdf:resource="#concept_indicator_VosprinimaemyyStress"/>
  <ruleMinSeverity rdf:resource="#SeverityHigh"/>
  <ruleRecommendsTask rdf:resource="#task_test_Pss"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rule_perceived_stress_high_pss</rdfs:label>
  <ruleWeight rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.9</ruleWeight>
  <ruleWhy rdf:datatype="http://www.w3.org/2001/XMLSchema#string">При высоком воспринимаемом стрессе полезно уточнить его выраженность тестом PSS.</ruleWhy>
  <ruleSWRL rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_VosprinimaemyyStress) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_perceived_stress_high_pss)</ruleSWRL>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#rule_anxiety_medium_breathing">

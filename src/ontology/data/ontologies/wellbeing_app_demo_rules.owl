Observation(?obs) ^ aboutIndicator(?obs, :concept_indicator_Trevozhnost) ^ hasSeverity(?obs, :SeverityHigh) -&gt; matchesRule(?obs, :rule_anxiety_medium_breathing)</ruleSWRL>
